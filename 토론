            let secId = wrap.dataset.secid;
            let idx = wrap.dataset.imgidx;
            if (secId && sectionImagesStorage[secId][idx]) {
                let state = sectionImagesStorage[secId][idx];
                let newW = wrap.style.width;
                let newH = wrap.style.height;
                if (state.w !== newW || state.h !== newH) {
                    state.w = newW;
                    state.h = newH;
                }
            }
        });
    });

    document.addEventListener('wheel', function(e) {
        if (e.target.classList.contains('wiki-panzoom-img')) {
            e.preventDefault(); 
            let type = e.target.dataset.type;
            let state;
            if (type === 'profile') state = profileTransform;
            else if (type === 'extra') state = extraTransform;
            else {
                let secId = e.target.dataset.secid;
                let idx = e.target.dataset.imgidx;
                state = sectionImagesStorage[secId][idx];
            }
            
            let zoom = e.deltaY < 0 ? 0.05 : -0.05;
            state.scale = Math.max(0.1, (state.scale || 1) + zoom);
            
            e.target.style.transform = `translate(${state.x}px, ${state.y}px) scale(${state.scale})`;
        }
    }, { passive: false });


