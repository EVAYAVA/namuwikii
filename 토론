                            <label style="font-size:10px; color:#666; display:flex; flex-direction:column; align-items:center; cursor:pointer;">테두리<input type="color" value="${cell.bd}" oninput="updateTableCell(${tIdx}, ${rIdx}, ${cIdx}, 'bd', this.value)" style="width:20px; height:20px; padding:0; border:none; cursor:pointer; margin-top:2px;"></label>
                        </div>
                    </td>`;
