    // --- 에디터 내 마우스 드래그 & 휠 기능 (크롭/리사이징) ---
    let isDraggingImg = false;
    let dragTarget = null;
    let startX, startY;
    let initialX, initialY;

    document.addEventListener('mousedown', function(e) {
        if (e.target.classList.contains('wiki-panzoom-img')) {
            e.preventDefault();
            isDraggingImg = true;
            dragTarget = e.target;
            dragTarget.style.cursor = 'grabbing';
            startX = e.clientX;
            startY = e.clientY;
            
            let type = dragTarget.dataset.type;
            let state;
            if (type === 'profile') state = profileTransform;
            else if (type === 'extra') state = extraTransform;
            else {
                let secId = dragTarget.dataset.secid;
                let idx = dragTarget.dataset.imgidx;
                state = sectionImagesStorage[secId][idx];
            }
            initialX = state.x || 0;
            initialY = state.y || 0;
        }
    });

    document.addEventListener('mousemove', function(e) {
        if (!isDraggingImg || !dragTarget) return;
        let dx = e.clientX - startX;
        let dy = e.clientY - startY;
        
        let type = dragTarget.dataset.type;
        let state;
        if (type === 'profile') state = profileTransform;
        else if (type === 'extra') state = extraTransform;
        else {
            let secId = dragTarget.dataset.secid;
            let idx = dragTarget.dataset.imgidx;
            state = sectionImagesStorage[secId][idx];
        }
        
        state.x = initialX + dx;
        state.y = initialY + dy;
        dragTarget.style.transform = `translate(${state.x}px, ${state.y}px) scale(${state.scale || 1})`;
    });

    document.addEventListener('mouseup', function(e) {
        if (isDraggingImg && dragTarget) {
            dragTarget.style.cursor = 'grab';
