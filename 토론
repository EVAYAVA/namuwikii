    function generateFullHTML() {
        const title = document.getElementById('in-title').value;
        const color = document.getElementById('in-color').value;
        const textColor = document.getElementById('in-text-color').value; 
        const editTime = document.getElementById('in-edit-time').value;
        const rawCategory = document.getElementById('in-category').value;
        const spoiler = document.getElementById('in-spoiler').checked;
        const infoTitle = document.getElementById('in-info-title').value;
        const infoSub = document.getElementById('in-info-sub').value;
        
        const showExtra = document.getElementById('in-show-extra').checked;
        document.getElementById('extra-settings-zone').style.display = showExtra ? 'block' : 'none';

        const catLines = rawCategory.split('\n').map(l => l.trim()).filter(l => l.includes('|'));
        const categoryHtml = catLines.map(line => {
            let parts = line.split('|');
            return `<a href="${parts.slice(1).join('|').trim()}" target="_blank" style="color: #0275d8; text-decoration: none;">${parts[0].trim()}</a>`;
        }).join(' <span style="color: #333; font-weight: normal; margin: 0 4px;">|</span> ');

        let infoRows = [];
        document.querySelectorAll('.info-row-item').forEach(row => {
            const id = row.id;
            const k = row.querySelector('.info-k').value;
            const v = row.querySelector('.info-v').value;
            if (k || v) infoRows.push({ id, k, v });
        });

        let sections = [];
        document.querySelectorAll('.section-block').forEach(block => {
            const id = block.id;
            sections.push({
                id: id,
                level: parseInt(block.querySelector('.sec-level').value),
                title: block.querySelector('.sec-title').value,
                content: block.querySelector('.sec-content').value,
                images: sectionImagesStorage[id] || []
            });
        });

        let fnIndex = 1;
        let footnotesList = [];

        // 글씨 꾸미기 태그들을 일괄 변환하는 함수
        function applyFormatting(text) {
            let res = text.replace(/\n/g, '<br>');
            res = res.replace(/\[굵게:(.*?)\]/g, '<strong style="font-weight: 900;">$1</strong>');
            res = res.replace(/\[링크:(.*?)\|([^\]]+)\]/g, '<a href="$2" target="_blank" style="color: #0275d8; text-decoration: underline;">$1</a>');
            res = res.replace(/\[색상:(.*?)\|([^\]]+)\]/g, '<span style="color: $2;">$1</span>');
            
            // 신규 텍스트 꾸미기
            res = res.replace(/\[취소선:(.*?)\]/g, '<span style="text-decoration: line-through; color: #999;">$1</span>');
            res = res.replace(/\[밑줄:(.*?)\]/g, '<span style="text-decoration: underline;">$1</span>');
            res = res.replace(/\[형광펜:([^\]|]+)(?:\|([^\]]+))?\]/g, function(m, t, c) {
                let bg = c ? c.trim() : '#fff2cc';
                return `<span style="background-color: ${bg};">${t}</span>`;
            });

            // 아이콘 파서
            res = res.replace(/\[아이콘:(\d+)\]/g, function(match, indexStr) {
                let idx = parseInt(indexStr) - 1;
                if (globalIconStorage[idx]) {
                    return `<img src="${globalIconStorage[idx]}" style="max-width:35px; max-height:35px; vertical-align:middle; border-radius:4px; margin: 0 2px; display:inline-block;" alt="아이콘">`;
                }
                return `[아이콘:${indexStr} 없음]`;
            });

            return res;
        }

        function parseText(text, secImages = [], secId = '') {
            let html = applyFormatting(text);
            
            // --- 글로벌 시각적 표(Table) 매칭 및 병합 연산 파서 ---
            html = html.replace(/\[표:(\d+)\]/g, function(match, tIdxStr) {
                let idx = parseInt(tIdxStr) - 1;
                let tData = globalTablesStorage[idx];
                if (!tData) return `[표:${tIdxStr} 없음]`;
                
                // 1. 계산용 복제본 생성
                let matrix = tData.map(row => row.map(cell => ({
                    v: cell.v.trim(), bg: cell.bg, c: cell.c, bd: cell.bd,
                    rowspan: 1, colspan: 1, hide: false, mergeTarget: null, mergedCells: []
                })));

                // 2. 가로 세로 병합 기호 탐색
                for (let r = 0; r < matrix.length; r++) {
                    for (let c = 0; c < matrix[r].length; c++) {
                        let cellText = matrix[r][c].v;
                        if (cellText === '[<]' && c > 0) {
                            matrix[r][c].mergeTarget = {r: r, c: c - 1};
                        } else if (cellText === '[^]' && r > 0) {
                            matrix[r][c].mergeTarget = {r: r - 1, c: c};
                        }
                    }
                }

                // 3. 병합의 뿌리(원본 셀) 찾기 함수
                function getRoot(r, c) {
                    let curr = matrix[r][c];
                    if (curr.mergeTarget) return getRoot(curr.mergeTarget.r, curr.mergeTarget.c);
                    return {r, c};
                }

                // 4. 모든 병합 대상을 숨김 처리하고 원본 셀에 기록
                for (let r = 0; r < matrix.length; r++) {
                    for (let c = 0; c < matrix[r].length; c++) {
                        if (matrix[r][c].mergeTarget) {
                            matrix[r][c].hide = true;
                            let root = getRoot(r, c);
                            matrix[root.r][root.c].mergedCells.push({r, c});
                        }
                    }
                }

                // 5. rowspan, colspan 계산 (2x2 다중 병합도 완벽히 지원)
                for (let r = 0; r < matrix.length; r++) {
                    for (let c = 0; c < matrix[r].length; c++) {
                        let cell = matrix[r][c];
                        if (!cell.hide && cell.mergedCells.length > 0) {
                            let maxR = r, maxC = c;
                            for (let mc of cell.mergedCells) {
                                if (mc.r > maxR) maxR = mc.r;
                                if (mc.c > maxC) maxC = mc.c;
                            }
                            cell.rowspan = maxR - r + 1;
                            cell.colspan = maxC - c + 1;
                        }
                    }
                }

                // 6. 표 HTML 조립
                let tHtml = '<div style="overflow-x: auto; margin: 15px 0;"><table style="width: 100%; border-collapse: collapse; font-size: 0.9em; min-width: 300px;">';
                for (let r = 0; r < matrix.length; r++) {
                    tHtml += '<tr>';
                    for (let c = 0; c < matrix[r].length; c++) {
                        let cell = matrix[r][c];
                        if (cell.hide) continue; // 병합당한 셀은 그리지 않음
                        
                        let cellTag = r === 0 ? 'th' : 'td';
                        let fw = r === 0 ? 'font-weight:bold;' : '';
                        let content = applyFormatting(cell.v); // 표 내부 꾸미기 적용
                        
                        let spanAttr = '';
                        if (cell.colspan > 1) spanAttr += ` colspan="${cell.colspan}"`;
                        if (cell.rowspan > 1) spanAttr += ` rowspan="${cell.rowspan}"`;

                        tHtml += `<${cellTag} ${spanAttr} style="border: 1px solid ${cell.bd}; padding: 8px; background-color: ${cell.bg}; color: ${cell.c}; text-align: center; word-break: break-word; ${fw}">${content}</${cellTag}>`;
                    }
                    tHtml += '</tr>';
                }
                tHtml += '</table></div>';
                return tHtml;
            });

            // --- 인용구 파서 ---
            html = html.replace(/\[인용구:([^\]|]+)(?:\|([^\]]+))?\]/g, function(match, mainText, subText) {
                let qHtml = `<div style="border-left: 3px solid ${color}; background-color: #f9f9f9; padding: 10px 15px; margin-bottom: 6px; font-family: 'Noto Sans JP', 'Pretendard', sans-serif; font-size: 0.85em; width: auto; max-width: 100%; box-sizing: border-box;">`;
                if (subText) {
                    qHtml += `<details style="cursor: pointer;"><summary style="list-style: none; outline: none; line-height: 1.6;"><style> summary::-webkit-details-marker { display: none; } </style>${mainText.trim()}</summary><div style="margin-top: 10px; padding-top: 10px; border-top: 1px solid #ddd; color: #666;">${subText.trim()}</div></details>`;
                } else {
                    qHtml += `<div style="line-height: 1.6;">${mainText.trim()}</div>`;
                }
                qHtml += `</div>`;
                return qHtml;
            });

            // --- 각주 파서 ---
            html = html.replace(/\[각주:(.*?)\]/g, function(match, fnContent) {
                let fnHtml = `<span class="footnote-container" tabindex="0"><span class="footnote-text">[${fnIndex}]</span><span class="footnote-content"><span class="fn-num">[${fnIndex}]</span> ${fnContent}<span class="fn-close-hint">닫으려면 바깥을 클릭하세요</span></span></span>`;
                footnotesList.push({ num: fnIndex, content: fnContent });
                fnIndex++;
                return fnHtml;
            });

            // --- 스포일러 파서 ---
            html = html.replace(/\[스포일러:(.*?)\]/g, function(match, fnContent) {
                let fnHtml = `<span class="footnote-container" tabindex="0"><span class="footnote-text">[스포일러]</span><span class="footnote-content"><span class="fn-num">[스포일러]</span> ${fnContent}<span class="fn-close-hint">닫으려면 바깥을 클릭하세요</span></span></span>`;
                return fnHtml;
            });

            let usedImageIndices = new Set();
            html = html.replace(/(?:\[사진:(\d+)(?:\|([^\]]+))?\])+/g, function(fullMatch) {
                let matchData = [];
                let regex = /\[사진:(\d+)(?:\|([^\]]+))?\]/g;
                let m;
                while ((m = regex.exec(fullMatch)) !== null) {
                    matchData.push({ idx: parseInt(m[1]) - 1, source: m[2] ? m[2].trim() : "" });
                }

                let validImages = matchData.filter(item => secImages[item.idx]);
                if (validImages.length === 0) return fullMatch;

                let groupHtml = `<div class="wiki-img-flex-group" style="display: flex; gap: 8px; flex-direction: row; flex-wrap: nowrap; margin: 10px 0; width: 100%; box-sizing: border-box; justify-content: center;">`;
                validImages.forEach(item => {
                    usedImageIndices.add(item.idx);
                    let imgObj = secImages[item.idx];
                    let src = typeof imgObj === 'string' ? imgObj : imgObj.src;
                    let x = imgObj.x || 0; let y = imgObj.y || 0; let scale = imgObj.scale || 1;

                    groupHtml += `
                    <div style="border: 1px solid #ccc; padding: 4px; background: #fff; flex: 1; max-width: calc(100% / ${validImages.length}); text-align: center; border-radius: 8px; box-sizing: border-box; overflow: hidden;">
                        <div style="width: 100%; height: 100%; overflow: hidden; border-radius: 4px;">
                            <img class="wiki-panzoom-img" data-type="section" data-secid="${secId}" data-imgidx="${item.idx}" src="${src}" style="width: 100%; height: 100%; object-fit: cover; display: block; margin: 0 auto; transform: translate(${x}px, ${y}px) scale(${scale}); cursor: grab; user-select: none;" draggable="false">
                        </div>
                        ${item.source ? `<div style="font-size: 11px; color: #888; margin-top: 4px; text-align: center; word-break: break-all;">ⓒ ${item.source}</div>` : ''}
                    </div>`;
                });
                groupHtml += `</div>`;
                return groupHtml;
            });

