    function triggerSecImageUpload(secId) { document.getElementById('file-input-' + secId).click(); }

    function handleSecImageFiles(input, secId) {
        if (!sectionImagesStorage[secId]) sectionImagesStorage[secId] = [];
        const files = input.files;
        if(files.length === 0) return;

        let processed = 0;
        Array.from(files).forEach(file => {
            const reader = new FileReader();
            reader.onload = e => {
                sectionImagesStorage[secId].push({
                    src: e.target.result, w: '100%', h: 'auto', x: 0, y: 0, scale: 1 
                }); 
                processed++;
                if (processed === files.length) {
                    input.value = ""; 
                    renderImgManagementList(secId);
                    updatePreview();
                }
            };
            reader.readAsDataURL(file);
        });
    }

    function removeSecImage(secId, index) {
        if (sectionImagesStorage[secId]) {
            sectionImagesStorage[secId].splice(index, 1); 
            renderImgManagementList(secId);
            updatePreview();
        }
    }

