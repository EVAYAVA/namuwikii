<script>
    function closeWelcomeModal() {
        document.getElementById('welcomeModal').style.display = 'none';
    }

    // --- 상태 저장 변수들 ---
    let srcProfileImg = "https://via.placeholder.com/300x380/eee/999?text=Profile+Image";
    let profileTransform = { x: 0, y: 0, scale: 1 };
    
    let srcExtraImg = ""; 
    let extraTransform = { x: 0, y: 0, scale: 1 };

    let sectionImagesStorage = {}; 
    let globalTablesStorage = []; // 본문 표 관리 글로벌 스토리지
    let globalIconStorage = []; 

    function handleProfileImage(input) {
        const file = input.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) { 
                srcProfileImg = e.target.result; 
                profileTransform = { x: 0, y: 0, scale: 1 }; 
                updatePreview(); 
            };
            reader.readAsDataURL(file);
        }
    }

    function handleExtraImage(input) {
        const file = input.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) { 
                srcExtraImg = e.target.result; 
                extraTransform = { x: 0, y: 0, scale: 1 };
                updatePreview(); 
            };
            reader.readAsDataURL(file);
        } else {
            srcExtraImg = "";
            updatePreview();
        }
    }

    // --- 글로벌 아이콘 처리 함수 ---
    function handleGlobalIconFiles(input) {
        const files = input.files;
        if(files.length === 0) return;
        let processed = 0;
        Array.from(files).forEach(file => {
            const reader = new FileReader();
            reader.onload = e => {
                globalIconStorage.push(e.target.result);
                processed++;
                if (processed === files.length) {
                    input.value = "";
                    renderGlobalIconList();
                    updatePreview();
                }
            };
            reader.readAsDataURL(file);
        });
    }

    function renderGlobalIconList() {
        const container = document.getElementById('global-icon-list');
        container.innerHTML = '';
        if (globalIconStorage.length === 0) {
            container.innerHTML = '<div style="color:#aaa; font-size:11px; text-align:center; padding:5px; border: 1px dashed #ccc; border-radius: 4px;">등록된 아이콘이 없습니다.</div>';
            return;
        }
        globalIconStorage.forEach((src, idx) => {
            const item = document.createElement('div');
            item.className = 'img-manage-item';
            item.innerHTML = `
                <img src="${src}" style="width:24px; height:24px;">
                <span style="flex:1; font-weight:bold; color:#008275;">[아이콘:${idx + 1}] 매칭</span>
                <button type="button" onclick="removeGlobalIcon(${idx})" style="background:#ff4d4f; color:white; border:none; padding:3px 6px; border-radius:3px; cursor:pointer; font-weight:bold;">지우기</button>
            `;
            container.appendChild(item);
        });
    }

    function removeGlobalIcon(idx) {
        globalIconStorage.splice(idx, 1);
        renderGlobalIconList();
        updatePreview();
    }


    // --- 표 항목 드래그 앤 드롭 함수들 ---
    let dragRowItem = null;
    function dragStartRow(e) {
        dragRowItem = e.currentTarget;
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', '');
        setTimeout(() => { dragRowItem.style.opacity = '0.4'; }, 0);
    }
    function dragOverRow(e) { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; }
    function dragEnterRow(e) {
        e.preventDefault();
        const target = e.currentTarget;
        if (target !== dragRowItem) {
            target.style.border = '2px dashed #008275';
        }
    }
    function dragLeaveRow(e) { e.currentTarget.style.border = '1px solid transparent'; }
    function dropRow(e) {
        e.preventDefault();
        const target = e.currentTarget;
        target.style.border = '1px solid transparent';
        if (dragRowItem && dragRowItem !== target) {
            const container = target.parentNode;
            const siblings = Array.from(container.children);
            const sourceIdx = siblings.indexOf(dragRowItem);
            const targetIdx = siblings.indexOf(target);
            if (sourceIdx < targetIdx) {
                container.insertBefore(dragRowItem, target.nextSibling);
            } else {
                container.insertBefore(dragRowItem, target);
            }
        }
    }
    function dragEndRow(e) {
        if(dragRowItem) dragRowItem.style.opacity = '1';
        document.querySelectorAll('.info-row-item').forEach(el => { el.style.border = '1px solid transparent'; });
        dragRowItem = null;
        updatePreview();
    }

    function addInfoRow(k = '', v = '', savedId = null) {
        const id = savedId || 'info-' + Date.now() + Math.floor(Math.random()*100);
        
        const html = `
            <div class="info-row-item" id="${id}" draggable="true" ondragstart="dragStartRow(event)" ondragover="dragOverRow(event)" ondragenter="dragEnterRow(event)" ondragleave="dragLeaveRow(event)" ondrop="dropRow(event)" ondragend="dragEndRow(event)" style="display:flex; gap:5px; margin-bottom:8px; align-items: flex-start; padding: 4px; border: 1px solid transparent; border-radius: 6px; background: #fff;">
                <div style="cursor: grab; padding: 8px 2px; color: #aaa; user-select: none;" title="드래그해서 순서 변경">≡</div>
                <input type="text" class="info-k" value="${k}" placeholder="항목명" style="width:75px; padding: 8px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;" oninput="updatePreview()">
                <div style="flex:1; display:flex; flex-direction:column; gap:4px;">
                    <textarea class="info-v" placeholder="내용 [아이콘:1] 사용 가능" style="width:100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; height: 35px; resize: vertical;" oninput="updatePreview()">${v}</textarea>
                </div>
                <button type="button" onclick="document.getElementById('${id}').remove(); updatePreview();" style="background:#ff4d4f; color:white; border:none; padding:8px 10px; border-radius:4px; cursor:pointer; font-weight:bold;">X</button>
            </div>
        `;
        document.getElementById('info-rows-container').insertAdjacentHTML('beforeend', html);
    }

    // --- 본문 문단 드래그 앤 드롭 함수들 ---
    let dragSecItem = null;
    function dragStartSec(e) {
        dragSecItem = e.currentTarget;
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', '');
        setTimeout(() => { dragSecItem.style.opacity = '0.4'; }, 0);
    }
    function dragOverSec(e) { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; }
    function dragEnterSec(e) {
        e.preventDefault();
        const target = e.currentTarget;
        if (target !== dragSecItem) {
            target.style.border = '2px dashed #008275';
        }
    }
    function dragLeaveSec(e) { e.currentTarget.style.border = '1px solid #ddd'; }
    function dropSec(e) {
        e.preventDefault();
        const target = e.currentTarget;
        target.style.border = '1px solid #ddd';
        if (dragSecItem && dragSecItem !== target) {
            const container = target.parentNode;
            const siblings = Array.from(container.children);
            const sourceIdx = siblings.indexOf(dragSecItem);
            const targetIdx = siblings.indexOf(target);
            if (sourceIdx < targetIdx) {
                container.insertBefore(dragSecItem, target.nextSibling);
            } else {
                container.insertBefore(dragSecItem, target);
            }
            updatePreview();
        }
    }
    function dragEndSec(e) {
        if(dragSecItem) dragSecItem.style.opacity = '1';
        document.querySelectorAll('.section-block').forEach(el => el.style.border = '1px solid #ddd');
        dragSecItem = null;
    }


    // --- 글로벌 시각적 표(Table) 생성기 함수들 ---
    function addGlobalTable() {
        const globalBg = document.getElementById('in-color').value;
        const globalTxt = document.getElementById('in-text-color').value;
        
        // 초기 기본 표 생성 (2x2)
        const newTable = [
            [ {v: '제목1', bg: globalBg, c: globalTxt, bd: '#cccccc'}, {v: '제목2', bg: globalBg, c: globalTxt, bd: '#cccccc'} ],
            [ {v: '내용1', bg: '#ffffff', c: '#333333', bd: '#cccccc'}, {v: '내용2', bg: '#ffffff', c: '#333333', bd: '#cccccc'} ]
        ];
        globalTablesStorage.push(newTable);
        renderGlobalTables();
        updatePreview();
    }

    function updateTableCell(tIdx, rIdx, cIdx, field, val) {
        globalTablesStorage[tIdx][rIdx][cIdx][field] = val;
        updatePreview();
    }

    function addTableRow(tIdx) {
        const table = globalTablesStorage[tIdx];
        const cols = table[0].length;
        const newRow = [];
        for(let i=0; i<cols; i++) newRow.push({v: '', bg: '#ffffff', c: '#333333', bd: '#cccccc'});
        table.push(newRow);
        renderGlobalTables();
        updatePreview();
    }
    
    function removeTableRow(tIdx) {
        const table = globalTablesStorage[tIdx];
        if (table.length > 1) { table.pop(); renderGlobalTables(); updatePreview(); }
    }
    
    function addTableCol(tIdx) {
        const table = globalTablesStorage[tIdx];
        const globalBg = document.getElementById('in-color').value;
        const globalTxt = document.getElementById('in-text-color').value;
        table.forEach((row, rIdx) => {
            if(rIdx === 0) row.push({v: '제목', bg: globalBg, c: globalTxt, bd: '#cccccc'});
            else row.push({v: '내용', bg: '#ffffff', c: '#333333', bd: '#cccccc'});
        });
        renderGlobalTables();
        updatePreview();
    }
    
    function removeTableCol(tIdx) {
        const table = globalTablesStorage[tIdx];
        if (table[0].length > 1) {
            table.forEach(row => row.pop());
            renderGlobalTables();
            updatePreview();
        }
    }
    
    function removeGlobalTable(tIdx) {
        globalTablesStorage.splice(tIdx, 1);
        renderGlobalTables();
        updatePreview();
    }

