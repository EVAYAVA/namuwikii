            html += `<div style="margin-top:10px; display:flex; gap:5px;">
                <button type="button" onclick="addTableRow(${tIdx})" style="font-size:12px; padding:6px 12px; border:1px solid #008275; background:#fff; color:#008275; border-radius:4px; cursor:pointer; font-weight:bold;">+ 행 추가</button>
                <button type="button" onclick="removeTableRow(${tIdx})" style="font-size:12px; padding:6px 12px; border:1px solid #ccc; background:#fff; border-radius:4px; cursor:pointer;">- 행 삭제</button>
                <button type="button" onclick="addTableCol(${tIdx})" style="font-size:12px; padding:6px 12px; border:1px solid #008275; background:#fff; color:#008275; border-radius:4px; cursor:pointer; font-weight:bold;">+ 열 추가</button>
                <button type="button" onclick="removeTableCol(${tIdx})" style="font-size:12px; padding:6px 12px; border:1px solid #ccc; background:#fff; border-radius:4px; cursor:pointer;">- 열 삭제</button>
